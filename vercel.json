{
  "version": 2,
  "buildCommand": "cd backend-node && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend-node/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SECRET_KEY": "@supabase_secret_key",
    "PORT": "3000"
  }
}   